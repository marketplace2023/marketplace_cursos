# ─── Database ───────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled)
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# ─── Auth ───────────────────────────────────────────────────
# Random 32+ char secret for JWT signing (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EduMarket

# ─── Email — Resend ─────────────────────────────────────────
# Get your key at https://resend.com — leave empty to skip email sending (logs token to console)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# "From" address (must be a verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.com

# ─── Payments — Stripe ──────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# Leave empty to disable Stripe checkout (shows informative fallback)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Storage (optional) ─────────────────────────────────────
# S3-compatible bucket for course covers, avatars, etc.
# STORAGE_ENDPOINT=https://s3.amazonaws.com
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_BUCKET=
# STORAGE_REGION=us-east-1
# NEXT_PUBLIC_STORAGE_URL=https://your-bucket.s3.amazonaws.com

# ─── Redis / Rate limiting (optional) ───────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
